generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
  CLIENT
}

enum BookingStatus {
  PENDING
  REVIEWING
  APPROVED
  DEPOSITED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  DRAFT
  PENDING
  PAID
  FULFILLED
  REFUNDED
  CANCELLED
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  WAITLIST
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CLIENT)
  twoFactorEnabled Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  orders        Order[]
  reviews       Review[]
  messages      Message[] @relation("MessageSender")
  favorites     Favorite[]
  activityLogs  ActivityLog[]
  loginHistory  LoginHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  type        String
  products    Product[]
  gallery     GalleryItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String      @db.Text
  price       Decimal     @db.Decimal(10, 2)
  compareAt   Decimal?    @db.Decimal(10, 2)
  stock       Int         @default(0)
  stockStatus StockStatus @default(IN_STOCK)
  images      String[]
  variants    Json?
  featured    Boolean     @default(false)
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  favorites   Favorite[]
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model GalleryItem {
  id         String    @id @default(cuid())
  title      String
  slug       String    @unique
  imageUrl   String
  videoUrl   String?
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  aspect     String    @default("square")
  featured   Boolean   @default(false)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  icon        String?
  imageUrl    String?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  packages    Package[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Package {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  priceFrom   Decimal   @db.Decimal(10, 2)
  features    String[]
  featured    Boolean   @default(false)
  serviceId   String?
  service     Service?  @relation(fields: [serviceId], references: [id])
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Theme {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  palette     String[]
  imageUrl    String?
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id          String        @id @default(cuid())
  code        String        @unique
  status      BookingStatus @default(PENDING)
  eventDate   DateTime
  guestCount  Int
  budget      Decimal       @db.Decimal(12, 2)
  location    String
  flowers     String[]
  notes       String?       @db.Text
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  packageId   String?
  package     Package?      @relation(fields: [packageId], references: [id])
  themeId     String?
  theme       Theme?        @relation(fields: [themeId], references: [id])
  contactName String
  contactEmail String
  contactPhone String?
  invoices    Invoice[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Order {
  id          String      @id @default(cuid())
  number      String      @unique
  status      OrderStatus @default(PENDING)
  total       Decimal     @db.Decimal(12, 2)
  currency    String      @default("USD")
  stripeId    String?
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  items       OrderItem[]
  invoices    Invoice[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
}

model Invoice {
  id        String   @id @default(cuid())
  number    String   @unique
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("USD")
  pdfUrl    String?
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String    @db.Text
  coverImage  String?
  category    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  seoTitle    String?
  seoDescription String?
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  author    String
  email     String
  approved  Boolean  @default(false)
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  quote     String   @db.Text
  name      String
  event     String?
  featured  Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  body      String   @db.Text
  read      Boolean  @default(false)
  userId    String?
  user      User?    @relation("MessageSender", fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  percent   Int?
  amount    Decimal?  @db.Decimal(10, 2)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  type      String
  width     Int?
  height    Int?
  alt       String?
  folder    String?
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model HomepageSection {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  enabled   Boolean  @default(true)
  content   Json
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

model NavigationItem {
  id        String   @id @default(cuid())
  label     String
  href      String
  location  String
  sortOrder Int      @default(0)
  parentId  String?
  parent    NavigationItem?  @relation("NavChildren", fields: [parentId], references: [id])
  children  NavigationItem[] @relation("NavChildren")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  meta      Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum CollectionStatus {
  AVAILABLE
  LIMITED
  RESERVED
  ARCHIVED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Collection {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  shortDescription   String
  description        String           @db.Text
  category           String
  occasion           String
  price              Decimal          @db.Decimal(10, 2)
  discountPrice      Decimal?         @db.Decimal(10, 2)
  premium            Boolean          @default(true)
  status             CollectionStatus @default(AVAILABLE)
  availabilityLabel  String           @default("Mövcuddur")
  includedGifts      String[]
  decorationDetails  String[]
  flowers            String[]
  ribbonType         String
  premiumMaterials   String[]
  colorTheme         String
  xoncaIncluded      Boolean          @default(true)
  tumbaIncluded      Boolean          @default(false)
  tumbaOptional      Boolean          @default(true)
  tumbaPrice         Decimal          @db.Decimal(10, 2) @default(0)
  deliveryAvailable  Boolean          @default(true)
  deliveryPrice      Decimal?         @db.Decimal(10, 2)
  preparationTime    String
  dimensions         String
  reservationInfo    String           @db.Text
  deliveryInfo       String           @db.Text
  maxQuantity        Int              @default(20)
  images             String[]
  videos             String[]
  seoTitle           String?
  seoDescription     String?
  faq                Json?
  unavailableDates   String[]
  reservations       Reservation[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Reservation {
  id               String            @id @default(cuid())
  number           String            @unique
  status           ReservationStatus @default(PENDING)
  collectionId     String?
  collection       Collection?       @relation(fields: [collectionId], references: [id])
  collectionName   String
  eventDate        DateTime
  xoncaQuantity    Int
  needTumba        Boolean           @default(false)
  tumbaQuantity    Int               @default(0)
  needDelivery     Boolean           @default(false)
  deliveryFee      Decimal           @db.Decimal(10, 2) @default(0)
  deliveryAddress  String?
  restaurantName   String
  customerName     String
  customerSurname  String
  phone            String
  email            String?
  notes            String?           @db.Text
  unitPrice        Decimal           @db.Decimal(10, 2)
  tumbaUnitPrice   Decimal           @db.Decimal(10, 2) @default(0)
  subtotal         Decimal           @db.Decimal(12, 2)
  total            Decimal           @db.Decimal(12, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model DeliverySetting {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(true)
  price     Decimal  @db.Decimal(10, 2) @default(150)
  updatedAt DateTime @updatedAt
}
